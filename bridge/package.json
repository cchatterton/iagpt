{
  "name": "analytics-chat-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Hosted bridge API for Analytics Chat for WordPress public GPT workflows.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
